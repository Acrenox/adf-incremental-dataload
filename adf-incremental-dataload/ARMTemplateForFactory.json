		{
			"name": "[concat(parameters('factoryName'), '/pl_ForEach_IncrementalLoad')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "lkp_GetLastProcessedDate",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "AzureSqlSource",
								"sqlReaderQuery": "SELECT last_processed_date\r\nFROM control.foreach_watermark\r\nWHERE table_name = 'sales_orders';",
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "ds_SalesOrders_Source",
								"type": "DatasetReference",
								"parameters": {}
							}
						}
					},
					{
						"name": "lkp_Generate_Process_Dates",
						"type": "Lookup",
						"dependsOn": [
							{
								"activity": "lkp_GetLastProcessedDate",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "AzureSqlSource",
								"sqlReaderQuery": "WITH DateCTE AS (\r\n    SELECT \r\n        CAST(last_processed_date AS DATE) AS process_date\r\n    FROM control.foreach_watermark\r\n    WHERE table_name = 'sales_orders'\r\n\r\n    UNION ALL\r\n\r\n    SELECT \r\n        DATEADD(DAY, 1, process_date)\r\n    FROM DateCTE\r\n    WHERE process_date < CAST(GETDATE() AS DATE)\r\n)\r\nSELECT process_date\r\nFROM DateCTE\r\nOPTION (MAXRECURSION 365);",
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "ds_ForEachWatermark",
								"type": "DatasetReference",
								"parameters": {}
							},
							"firstRowOnly": false
						}
					},
					{
						"name": "fe_ProcessDates",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "lkp_Generate_Process_Dates",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('lkp_Generate_Process_Dates').output.value",
								"type": "Expression"
							},
							"batchCount": 5,
							"activities": [
								{
									"name": "gm_Check_Source_Table",
									"type": "GetMetadata",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"dataset": {
											"referenceName": "ds_SalesOrders_Source",
											"type": "DatasetReference",
											"parameters": {}
										},
										"fieldList": [
											"exists"
										]
									}
								},
								{
									"name": "cpy_sales_orders_incremental",
									"type": "Copy",
									"dependsOn": [
										{
											"activity": "gm_Check_Source_Table",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {

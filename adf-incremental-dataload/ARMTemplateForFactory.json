											"name": "quantity",
											"type": "int",
											"physicalType": "int",
											"precision": 10
										},
										"sink": {
											"name": "quantity",
											"type": "int",
											"physicalType": "int",
											"precision": 10
										}
									},
									{
										"source": {
											"name": "unit_price",
											"type": "float",
											"physicalType": "float",
											"precision": 15
										},
										"sink": {
											"name": "unit_price",
											"type": "float",
											"physicalType": "float",
											"precision": 15
										}
									},
									{
										"source": {
											"name": "total_amount",
											"type": "float",
											"physicalType": "float",
											"precision": 15
										},
										"sink": {
											"name": "total_amount",
											"type": "float",
											"physicalType": "float",
											"precision": 15
										}
									},
									{
										"source": {
											"name": "order_status",
											"type": "varchar",
											"physicalType": "varchar"
										},
										"sink": {
											"name": "order_status",
											"type": "varchar",
											"physicalType": "varchar"
										}
									},
									{
										"source": {
											"name": "modified_date",
											"type": "datetime",
											"physicalType": "datetime",
											"scale": 3,
											"precision": 23
										},
										"sink": {
											"name": "modified_date",
											"type": "datetime",
											"physicalType": "datetime",
											"scale": 3,
											"precision": 23
										}
									}
								],
								"typeConversion": true,
								"typeConversionSettings": {
									"allowDataTruncation": true,
									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [

								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"storedProcedureName": "[[control].[usp_UpdateCDCWatermark]",
							"storedProcedureParameters": {
								"last_lsn": {
									"value": {
										"value": "@{activity('lkp_GetCurrentLSN').output.firstRow.current_lsn}",
										"type": "Expression"
									},
									"type": "String"
								},
								"table_name": {
									"value": "sales_orders",
									"type": "String"
								}
							}
						},
						"linkedServiceName": {
							"referenceName": "ls_azuresql_incremental_dataload",
							"type": "LinkedServiceReference"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": [],
				"lastPublishTime": "2026-03-02T09:07:02Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_CDCWatermark')]",
				"[concat(variables('factoryId'), '/datasets/ds_SalesOrders_Source')]",
				"[concat(variables('factoryId'), '/datasets/ds_SalesOrders_CDCSink')]",
				"[concat(variables('factoryId'), '/linkedServices/ls_azuresql_incremental_dataload')]"
			]
		},
